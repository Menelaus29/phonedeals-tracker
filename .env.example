# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
# Create a bot via @BotFather and copy the token here.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjklMnoPqRsTuVwXyZ

# The chat_id where deal alerts will be sent.
# DM @userinfobot on Telegram to find your chat_id.
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────────
# Playwright
# ─────────────────────────────────────────────
# Directory to store the persistent browser session (for Facebook login).
# The bot will create this automatically on first run.
BROWSER_DATA_DIR=./browser_data

# Set to "true" to hide the browser window during scraping.
# Set to "false" to see the browser window (useful for debugging CAPTCHAs).
HEADLESS=true

# ─────────────────────────────────────────────
# Matching Engine
# ─────────────────────────────────────────────
# Minimum fuzzy similarity score (0-100) to consider a listing a match.
FUZZY_THRESHOLD=85

# Maximum age of a listing in days to be considered for alerts.
# Applies only to classifieds (Chotot, Facebook). Retail stores bypass this.
MAX_AGE_DAYS=15

# ─────────────────────────────────────────────
# Facebook
# ─────────────────────────────────────────────
# Comma-separated list of Facebook Group URLs to monitor.
# Leave empty to only monitor Marketplace.
FB_GROUP_URLS=https://www.facebook.com/groups/123456789,https://www.facebook.com/groups/987654321
